# ─────────────────────────────────────────────
#  ERP Monitor — environment configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Flask
FLASK_DEBUG=false
PORT=5000

# Security — CHANGE THESE before deploying
SECRET_KEY=super-secret-jwt-key-change-me
API_KEY=dev-api-key-change-me
ADMIN_PASSWORD=admin

# Database
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///monitor.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/erp_monitor

# How often to run health checks (seconds)
CHECK_INTERVAL_SECONDS=60

# JWT token expiry
JWT_EXPIRY_HOURS=8

